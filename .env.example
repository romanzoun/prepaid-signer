# ─────────────────────────────────────────────────────────────────────────────
# SwissSigner – Environment Variables
# Copy this file to .env and fill in the real values.
# .env is git-ignored and NEVER committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Swisscom Sign API ─────────────────────────────────────────────────────────
# Set SWISSCOM_SIGN_MOCK=true to use the built-in mock (default, no credentials needed).
# Set SWISSCOM_SIGN_MOCK=false to call the real Swisscom All-in Signing Service.

SWISSCOM_SIGN_MOCK=true
SWISSCOM_SIGN_API_URL=https://sign.swisscom.ch/api
SWISSCOM_SIGN_TOKEN_URL=https://sign.swisscom.ch/oauth/token
SWISSCOM_SIGN_CLIENT_ID=your_swisscom_client_id_here
SWISSCOM_SIGN_CLIENT_SECRET=your_swisscom_client_secret_here

# ── Stripe ────────────────────────────────────────────────────────────────────
# Set STRIPE_MOCK=true to simulate payment (default, no credentials needed).
# Set STRIPE_MOCK=false to call the real Stripe API.
# Use test keys (sk_test_...) during development, live keys (sk_live_...) in production.

STRIPE_MOCK=true
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
UPLOAD_DIR=/app/uploads
LOG_DEBUG_SWISSCOM_SIGN=false
# Optional override (default: ${UPLOAD_DIR}/swisscom-sign-debug.log)
LOG_DEBUG_SWISSCOM_SIGN_FILE=/app/logs/swisscom-sign-debug.log

# ── Experimental Features ─────────────────────────────────────────────────────
# AI contract analyzer step in UI and backend APIs (default off)
CONTRACT_ANALYZER_ENABLED=false
